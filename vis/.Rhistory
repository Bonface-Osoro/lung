library(data.table)
# Load the CSV file using fread
data <- fread("C:\\Users\\Admin\\OneDrive\\University of Cincinnati\\Research\\WQ Shared\\TP_WQP.csv", stringsAsFactors = FALSE)
# Display the first few rows of the data
head(data)
library(data.table)
# Load the CSV file using fread
data <- fread("TP_WQP.csv", stringsAsFactors = FALSE)
# Display the first few rows of the data
head(data)
library(data.table)
GRQA <- data[, c("site_id", "site_name", "site_country", "lat_wgs84", "lon_wgs84", "obs_date", "obs_value", "unit")]
# Assuming GRQA is a data.table
GRQA <- data.table(GRQA)
# Assigning values to columns
GRQA[, `River Width` := NA]
GRQA[, `Method Name` := NA]
GRQA[, `Collection Agency` := NA]
GRQA[, `Data Source` := "GRQA"]
GRQA[, Comment := "Published Version"]
GRQA[, Parameter := "Total Phosphorus"]
# Define a named vector for renaming columns
rename_dict <- c("Station Identifier" = "site_id",
"Station Name" = "site_name",
"Country" = "site_country",
"Latitude" = "lat_wgs84",
"Longitude" = "lon_wgs84",
"Sampling Date" =  "obs_date",
"Measurement Value" = "obs_value",
"Unit" =  "unit"
)
# Rename the columns in the DataFrame
GRQA <- GRQA %>% rename(!!!rename_dict)
GRQA$`Sampling Date` <- as.Date(GRQA$`Sampling Date`)
# Extract rows where 'Sampling Date' is NA
na_rows_sampling_date <- GRQA[is.na(GRQA$`Sampling Date`), ]
GRQA <- GRQA[!is.na(GRQA$`Sampling Date`), ]
GRQA <- na.omit(GRQA, cols = "Latitude")
GRQA <- na.omit(GRQA, cols = "Longitude")
GRQA <- na.omit(GRQA, cols = "Measurement Value")
GRQA <- na.omit(GRQA, cols = "Unit")
GRQA <- GRQA[GRQA$`Sampling Date` >= as.Date("1984-01-01"), ]
# Define column types
column_types <- list(
"Station Identifier" = "character",
"Station Name" = "character",
"Country" = "character",
"Latitude" = "numeric",  # Assuming actual numeric data for Latitude
"Longitude" = "numeric", # Assuming actual numeric data for Longitude
"Sampling Date" = "date",
"Measurement Value" = "numeric", # Assuming numeric values for Measurement
"Unit" = "character",
"River Width" = "numeric",  # Assuming numeric values for River Width
"Collection Agency" = "character",
"Method Name" = "character",
"Data Source" = "character",
"Comment" = "character",
"Parameter" = "character"
)
# Convert column types function
convert_column_types <- function(df, types) {
for (col in names(types)) {
if (col %in% names(df)) {  # Check if column exists in DataFrame
if (types[[col]] == "character") {
df[[col]] <- as.character(df[[col]])
} else if (types[[col]] == "numeric") {
df[[col]] <- as.numeric(df[[col]])
} else if (types[[col]] == "integer") {
df[[col]] <- as.integer(df[[col]])
} else if (types[[col]] == "date") {
df[[col]] <- as.Date(df[[col]], format = "%Y-%m-%d")  # Adjust format as needed
}
# Add more type handling if needed
} else {
warning(paste("Column", col, "is not found in the DataFrame"))
}
}
return(df)
}
# Apply the conversion to the GRQA DataFrame
GRQA <- convert_column_types(GRQA, column_types)
# Write the DataFrame to a Feather file
write_feather(data, "TP_database.feather")
# Write the DataFrame to a Feather file
write_feather(data, "TP_database.feather")
# Write the DataFrame to a Feather file
write_feather("TP_database.feather")
View(data)
View(data)
